# Startup Idea Scout — Docker Compose environment variables
# Copy to .env and fill in your values

# OpenAI API key (required for LLM scoring, problem extraction, deep-dive research)
SCOUT_OPENAI_API_KEY=sk-...

# CamoFox browser — set CAMOFOX_AUTH_MODE=auto to enable API key auth
# When CAMOFOX_AUTH_MODE=disabled (default), no key is needed between containers
CAMOFOX_API_KEY=

# GitHub personal access token (optional — increases API rate limit from 10 to 30 req/min)
SCOUT_GITHUB_TOKEN=
