# Scout — Startup Idea Scout Configuration
# Copy to .env and fill in your values

# OpenAI API key (required for LLM scoring, problem extraction, deep-dive research)
SCOUT_OPENAI_API_KEY=

# CamoFox stealth browser (no API keys for Reddit/Twitter — browser handles authentication)
SCOUT_BROWSER_API_URL=http://localhost:9377
SCOUT_BROWSER_USER_ID=scout

# GitHub personal access token (optional — increases API rate limit from 10 to 30 req/min)
SCOUT_GITHUB_TOKEN=

# Reddit & Twitter API keys — not needed. Scout uses CamoFox browser for all fetching.
# Set these only if you want to fall back to API-based scraping.
# SCOUT_REDDIT_CLIENT_ID=
# SCOUT_REDDIT_CLIENT_SECRET=
# SCOUT_X_BEARER_TOKEN=
# Scraping intervals (in minutes)
SCOUT_SCRAPE_INTERVAL_MINUTES=15
SCOUT_DEEP_DIVE_INTERVAL_MINUTES=5

# Active hours (24h format) — scrapers only run during this window
SCOUT_ACTIVE_HOURS_START=6
SCOUT_ACTIVE_HOURS_END=23

# Scoring thresholds
SCOUT_MAX_IDEAS_TRACKED=500
SCOUT_ALERT_THRESHOLD=70

# LLM model for scoring
SCOUT_LLM_MODEL=gpt-4o-mini

# WorldMonitor URL (separate Node.js process)
SCOUT_WORLDMONITOR_URL=http://localhost:3000

# Data storage paths (defaults to ~/.scout/)
# SCOUT_DATA_DIR=
# SCOUT_DB_PATH=
# SCOUT_PROFILE_PATH=

# Knowledge graph path (defaults to ~/research/startup-idea-finder/graphify-out/graph.json)
# SCOUT_GRAPH_PATH=
